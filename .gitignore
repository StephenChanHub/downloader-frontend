
# =========================
# 1. 依赖文件 (Dependencies)
# =========================
node_modules/
# 如果你团队统一使用 pnpm 或 yarn，可以忽略 package-lock.json
# package-lock.json 

# =========================
# 2. 环境变量与机密 (Secrets)
# =========================
# 绝对不能把数据库密码、JWT 密钥推送到公开仓库！
.env
.env.local
.env.development
.env.test
*.pem

# =========================
# 3. 前端构建产物 (Build Outputs)
# =========================
dist/
build/
.tscache/

# =========================
# 4. 私有业务数据 (核心保护)
# =========================
# 拦截所有本地测试上传的 PDF 文件和挂载的持久卷目录
/storage/
/data/
/uploads/
*.pdf

# =========================
# 5. 系统与日志文件 (OS & Logs)
# =========================
.DS_Store
Thumbs.db
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# =========================
# 6. 编辑器与 IDE 缓存 (IDE)
# =========================
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?